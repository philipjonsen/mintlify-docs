  "keyFeatures": [
    "Workspace and project management with RBAC",
    "Analytics dashboards with charts and visualizations",
    "Scheduled report delivery via email and Slack",
    "Data source connections (databases, warehouses, SaaS tools)",
    "Pre-built integration connectors (CRM, productivity, communication)",
    "OAuth 2.0, API key, and service account authentication",
    "Event-driven webhooks with HMAC signature verification",
    "Bulk user management with CSV import",
    "SSO via SAML 2.0 and OIDC",
    "Custom roles with granular permission sets"
  ],
  "publicApiSurface": [
    "API keys (workspace-scoped, read/read-write)",
    "Webhook endpoints (POST, X-Signature-256 HMAC-SHA256 verification)",
    "Data source connection API (Test connection, sync frequency)",
    "OAuth 2.0 authorization flow for integrations",
    "Service account credentials (JSON key upload)",
    "CSV bulk import (email, role, first_name, last_name columns)",
    "Webhook event types and payload schemas",
    "CRM field mapping editor",
    "Dashboard embed codes and shareable links"
