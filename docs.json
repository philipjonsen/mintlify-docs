{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Black Raven Institution",
  "description": "Set up your workspace, build analytics dashboards, and connect your tools—everything you need to get the most out of Black Raven Institution.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "tabs": [
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "platform/quickstart",
              "platform/key-concepts"
            ]
          },
          {
            "group": "Configuration",
            "icon": "settings",
            "pages": [
              "platform/configuration/settings",
              "platform/configuration/user-management",
              "platform/administration/roles-permissions"
            ]
          }
        ]
      },
      {
        "tab": "Analytics",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "analytics/quickstart",
              "analytics/connect-data"
            ]
          },
          {
            "group": "Dashboards & Reports",
            "icon": "chart-bar",
            "pages": [
              "analytics/dashboards/create-dashboard",
              "analytics/reports/scheduled-reports"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "integrations/quickstart",
              "integrations/authentication"
            ]
          },
          {
            "group": "Connectors & Webhooks",
            "icon": "plug",
            "pages": [
              "integrations/connectors/crm",
              "integrations/webhooks/configure"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.blackraveninstitution.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/blackraveninstitution",
      "linkedin": "https://linkedin.com/company/blackraveninstitution"
    }
  }
}
